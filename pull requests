# FILE: tools/autopush.sh
#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${REPO_DIR:-$(pwd)}"
REMOTE_URL="${REMOTE_URL:-git@github.com:blackboxprogramming/blackboxprogramming.git}"
BRANCH="${BRANCH:-main}"
SSH_KEY="${SSH_KEY:-$HOME/.ssh/id_ed25519}"

# Known host fingerprints you shared previously
declare -A HOST_FP=(
  ["github.com"]="SHA256:p2QAMXNIC1TJYWeIOttrVc98/R1BUFWu3/LiyKgUfQM="
  ["gitlab.com"]="SHA256:HbW3g8zUjNSksFbqTiUWPWg2Bq1x8xdGUrliXFzSnUw="
  ["bitbucket.org"]="SHA256:FC73VB6C4OQLSCrjEayhMp9UMxS97caD/Yyi2bhW/J0="
)

ensure_known_host () {
  local host=$1 fp_expected=$2
  mkdir -p "$HOME/.ssh"
  touch "$HOME/.ssh/known_hosts"
  chmod 600 "$HOME/.ssh/known_hosts"
  if ! ssh-keygen -F "$host" >/dev/null 2>&1; then
    ssh-keyscan -t rsa,ecdsa,ed25519 "$host" >> "$HOME/.ssh/known_hosts" 2>/dev/null || true
  fi
  local fp
  fp=$(ssh-keygen -lf <(ssh-keyscan -t rsa,ecdsa,ed25519 "$host" 2>/dev/null | awk '{print $3" "$4" "$5}'))
  if [[ "$fp" != *"$fp_expected"* ]]; then
    echo "Fingerprint mismatch for $host"; exit 1
  fi
}

host=$(echo "$REMOTE_URL" | awk -F'[@:]' '{print $2}')
[ -n "${HOST_FP[$host]:-}" ] && ensure_known_host "$host" "${HOST_FP[$host]}"

if [ -f "$SSH_KEY" ]; then
  eval "$(ssh-agent -s)"
  ssh-add "$SSH_KEY"
fi

cd "$REPO_DIR"
git remote set-url origin "$REMOTE_URL" || git remote add origin "$REMOTE_URL" || true
git fetch origin || true
git checkout -B "$BRANCH"
git add -A
git commit -m "autopush: $(date -u +'%Y-%m-%dT%H:%M:%SZ')" || echo "No changes to commit."
for i in {1..5}; do
  if git push -u origin "$BRANCH"; then
    echo "Push ok."; exit 0
  fi
  echo "Retry $i…"; sleep $((i*2))
done
echo "Push failed after retries."; exit 1

