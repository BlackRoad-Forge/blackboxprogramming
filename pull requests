# FILE: .github/workflows/ops.yml
name: BlackRoad Ops (Agentless)

on:
  workflow_dispatch:
    inputs:
      task:
        description: "What should the ops runner do? (e.g., issues:sync, plan:security, run:script tools/autopush.sh)"
        required: true
        default: "issues:sync"
      ref:
        description: "Git ref to checkout (branch or tag)"
        required: false
        default: "main"
  schedule:
    - cron: "*/30 * * * *"  # every 30 minutes keep things tidy (safe to disable)

permissions:
  contents: write
  issues: write
  pull-requests: write

jobs:
  ops:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.inputs.ref }}
          fetch-depth: 0

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install deps (if present)
        run: |
          set -e
          if [ -f requirements.txt ]; then pip install -r requirements.txt; fi
          pip install requests pyyaml

      - name: Run task switchboard
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GH_REPO: ${{ github.repository }}
          TASK: ${{ github.event.inputs.task }}
        run: |
          set -euo pipefail
          echo "Task: ${TASK}"
          case "${TASK}" in
            issues:sync)
              python tools/issue_sync.py
              ;;
            run:script\ *)
              # Example: run:script tools/autopush.sh
              SCRIPT="${TASK#run:script }"
              echo "Running script ${SCRIPT}"
              chmod +x "${SCRIPT}"
              "${SCRIPT}"
              ;;
            *)
              echo "Unknown task '${TASK}'. Supported: issues:sync, run:script <path>"
              exit 1
              ;;
          esac

      - name: Commit any repo changes (if any)
        run: |
          set -e
          if ! git diff --quiet; then
            git config user.name "blackroad-ops"
            git config user.email "ops@users.noreply.github.com"
            git add -A
            git commit -m "ops: automated update from workflow ${GITHUB_RUN_ID}"
            git push
          else
            echo "No changes to commit."
          fi

# FILE: tools/issue_sync.py
import os, json, requests, sys
from typing import List, Dict

MANIFEST_PATHS = [
    ".blackroad/issue-manifest.json",
    "blackroad-plans/.blackroad/issue-manifest.json",
]

GITHUB_TOKEN = os.getenv("GITHUB_TOKEN")
REPO = os.getenv("GH_REPO")  # e.g., "blackboxprogramming/blackboxprogramming"

API = "https://api.github.com"

def load_manifest() -> Dict:
    for p in MANIFEST_PATHS:
        if os.path.exists(p):
            with open(p, "r", encoding="utf-8") as f:
                return json.load(f)
    print("No manifest found; skipping.", file=sys.stderr)
    return {}

def gh(headers, method, url, **kw):
    r = requests.request(method, url, headers=headers, **kw)
    if r.status_code >= 300:
        raise RuntimeError(f"GitHub API error {r.status_code}: {r.text}")
    return r.json()

def get_existing_titles(headers) -> Dict[str,int]:
    titles = {}
    page = 1
    while True:
        r = requests.get(f"{API}/repos/{REPO}/issues?state=open&per_page=100&page={page}", headers=headers)
        if r.status_code != 200:
            raise RuntimeError(r.text)
        items = r.json()
        if not items:
            break
        for it in items:
            if "pull_request" in it:  # skip PRs
                continue
            titles[it["title"].strip()] = it["number"]
        page += 1
    return titles

def ensure_issues(headers, issues: List[str], assignee: str|None):
    existing = get_existing_titles(headers)
    created, skipped = [], []
    for title in issues:
        t = title.strip()
        if t in existing:
            skipped.append(t)
            continue
        payload = {"title": t}
        if assignee:
            payload["assignees"] = [assignee]
        data = gh(headers, "POST", f"{API}/repos/{REPO}/issues", json=payload)
        created.append(data["html_url"])
    return created, skipped

def main():
    if not GITHUB_TOKEN or not REPO:
        print("Missing GITHUB_TOKEN or GH_REPO", file=sys.stderr); sys.exit(0)

    headers = {"Authorization": f"Bearer {GITHUB_TOKEN}", "Accept": "application/vnd.github+json"}
    manifest = load_manifest()
    if not manifest:
        print("No manifest; done."); return

    issues = manifest.get("issues", [])
    assignee = manifest.get("assignee")
    created, skipped = ensure_issues(headers, issues, assignee)
    print(f"Created: {len(created)} | Skipped (already present): {len(skipped)}")
    if created:
        for url in created:
            print(f" - {url}")

if __name__ == "__main__":
    main()

