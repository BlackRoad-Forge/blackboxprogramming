# ── Ollama (local AI - no external provider required) ─────────────────────────
# Port Ollama listens on (default: 11434)
OLLAMA_PORT=11434

# Ollama API base URL (used by apps connecting to the local instance)
OLLAMA_HOST=http://localhost:11434

# Default model to pull on first run.
# Browse available models at https://ollama.com/library
# Lightweight options : llama3.2, mistral, phi3, gemma2:2b
# Powerful options    : llama3.1:70b, mixtral, deepseek-r1:14b
OLLAMA_DEFAULT_MODEL=llama3.2
