# Example environment configuration for the Superior AI platform

# Secret key used for signing JWTs and other cryptographic operations.
SECRET_KEY=your-secret-key-here

# Database connection string. When running locally you can use SQLite; in production use
# a managed PostgreSQL instance.
DATABASE_URL=sqlite:///./data/database.db

# Allowed hosts for CORS. Use comma-separated values.
ALLOWED_HOSTS=*

# Algorithm used to sign tokens
ALGORITHM=HS256

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
