# Blackboxprogramming Ollama Extension — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit a populated .env file.

# ---------------------------------------------------------------------------
# Ollama settings
# ---------------------------------------------------------------------------

# Base URL of your Ollama server (default: local instance)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (any model you have pulled via `ollama pull <name>`)
OLLAMA_MODEL=llama3

# ---------------------------------------------------------------------------
# Server settings
# ---------------------------------------------------------------------------

# Port the extension listens on (GitHub Copilot will call this endpoint)
PORT=3000
