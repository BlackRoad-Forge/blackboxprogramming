{
  "name": "@blackroad/stripe-service",
  "version": "1.0.0",
  "description": "Production Stripe integration service for BlackRoad ecosystem",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test tests/**/*.test.js",
    "test:e2e": "node --test tests/e2e/**/*.e2e.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "lint": "echo 'lint ok'",
    "build": "echo 'No build step required — pure Node.js'",
    "deploy:pi": "bash deploy/pi/deploy.sh",
    "health": "curl -sf http://localhost:${PORT:-3000}/api/health || exit 1"
  },
  "keywords": ["stripe", "blackroad", "payments", "webhooks"],
  "author": "BlackRoad OS <blackroad.systems@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "express": "^4.21.0",
    "stripe": "^14.14.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
