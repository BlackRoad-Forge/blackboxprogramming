<!-- FILE: .github/workflows/auto-merge.yml -->
name: Auto Merge (Lucidia)

on:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review, labeled]
  check_suite:
    types: [completed]
  workflow_dispatch:

permissions:
  contents: write
  pull-requests: write

jobs:
  merge:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/github-script@v7
        with:
          script: |
            const owner = context.repo.owner, repo = context.repo.repo;
            // find the candidate PR (from event or list)
            let pr = context.payload.pull_request;
            if (!pr) {
              const { data: prs } = await github.pulls.list({ owner, repo, state: "open" });
              pr = prs.find(p => p.head.ref === "auto/lucidia-ops" || p.head.ref.startsWith("auto/ingest-"));
              if (!pr) { core.notice("No matching auto PR open."); return; }
            }
            const labels = pr.labels.map(l => l.name);
            if (!labels.includes("auto")) { core.notice("Missing 'auto' label; skipping."); return; }

            // combined status on head SHA
            const { data: status } = await github.repos.getCombinedStatusForRef({ owner, repo, ref: pr.head.sha });
            const checksOK = (status.state === "success" || status.statuses.length === 0);

            if (!checksOK) { core.notice("Checks not successful; will retry on next event."); return; }
            if (pr.mergeable === false) { core.notice(`PR #${pr.number} not mergeable yet.`); return; }

            await github.pulls.merge({
              owner, repo, pull_number: pr.number, merge_method: "squash"
            });
            core.notice(`Merged PR #${pr.number}`);